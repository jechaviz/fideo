{
  "name": "fideo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.8",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "bun run lint:typecheck && bun run lint:eslint",
    "lint:typecheck": "tsc --noEmit",
    "lint:eslint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "pb:install": "bun run scripts/pocketbase-cli.mjs install",
    "pb:start": "bun run scripts/pocketbase-cli.mjs start",
    "pb:bootstrap": "bun run scripts/pocketbase-cli.mjs bootstrap",
    "pb:check": "powershell -ExecutionPolicy Bypass -Command '& { node --check ../backend/pocketbase/pb_hooks/fideo.pb.js; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; Get-ChildItem ../backend/pocketbase/pb_migrations/*.js | ForEach-Object { node --check $_.FullName; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE } } }'"
  },
  "dependencies": {
    "@google/genai": "^1.8.0",
    "pocketbase": "^0.26.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-onesignal": "^3.5.1",
    "recharts": "^3.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
